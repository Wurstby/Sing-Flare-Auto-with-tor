{
  "log": {
    "level": "info"
  },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "::",
      "listen_port": 8080,
      "users": [
        {
          "uuid": "PASTE_YOUR_UUID_HERE"
        }
      ],
      "transport": {
        "type": "ws",
        "path": "/vless"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "socks",
      "tag": "tor-out",
      "server": "127.0.0.1",
      "server_port": 9050
    }
  ],
  "route": {
    "rules": [
      {
        "domain_suffix": [
          ".onion"
        ],
        "outbound": "tor-out"
      }
    ],
    "final": "direct"
  }
}